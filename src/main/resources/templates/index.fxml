<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.*?>
<?import javafx.scene.layout.*?>
<BorderPane prefHeight="650.0" prefWidth="1100.0" style="-fx-background-color: #F5F5F5;"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ronald.app.prueba.controller.IndexController">

    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #2C3E50; -fx-padding: 20 30;">
            <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 300; -fx-font-family: 'Segoe UI', System;"
                   text="Gestión de Tareas"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="20" style="-fx-padding: 25;">

            <VBox prefWidth="300" spacing="15"
                  style="-fx-background-color: white; -fx-background-radius: 4; -fx-padding: 20;
                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-border-color: #E0E0E0; -fx-border-radius: 4;">

                <Label style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #2C3E50;"
                       text="Nueva Tarea"/>

                <VBox spacing="5">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #7F8C8D;"
                           text="TAREA"/>
                    <TextField fx:id="tareaTexto"
                               promptText="Ingrese nombre"
                               style="-fx-background-color: #F9F9F9; -fx-border-color: #E0E0E0; -fx-border-radius: 2; -fx-padding: 8;"/>
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #7F8C8D;"
                           text="RESPONSABLE"/>
                    <TextField fx:id="responsableTexto"
                               promptText="Ingrese responsable"
                               style="-fx-background-color: #F9F9F9; -fx-border-color: #E0E0E0; -fx-border-radius: 2; -fx-padding: 8;"/>
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #7F8C8D;"
                           text="ESTADO"/>
                    <ComboBox fx:id="estadoCBX" prefHeight="27.0"
                              prefWidth="255.0"
                              promptText="Seleccionar"
                              style="-fx-background-color: #F9F9F9; -fx-border-color: #E0E0E0; -fx-border-radius: 2;"/>
                </VBox>

                <Separator style="-fx-background: #E0E0E0;"/>

                <Label style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #2C3E50;"
                       text="Cantidad"/>

                <Button onAction="#mostrarTareasPendientesBtn" prefHeight="35.0" prefWidth="105.0"
                        style="-fx-background-color: transparent; -fx-border-color: #BDC3C7; -fx-border-radius: 2; -fx-text-fill: #34495E; -fx-padding: 8;"
                        text="Pendientes">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </Button>

                <Button onAction="#mostrarTareasEnProcesoBtn" prefHeight="35.0" prefWidth="104.0"
                        style="-fx-background-color: transparent; -fx-border-color: #BDC3C7; -fx-border-radius: 2; -fx-text-fill: #34495E; -fx-padding: 8;"
                        text="En Proceso">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </Button>

                <Button onAction="#mostrarTareasFinalizadasBtn" prefHeight="35.0" prefWidth="102.0"
                        style="-fx-background-color: transparent; -fx-border-color: #BDC3C7; -fx-border-radius: 2; -fx-text-fill: #34495E; -fx-padding: 8;"
                        text="Finalizadas">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </Button>

                <Button fx:id="mostrarTareasTotalesId" onAction="#mostrarTareasTotalesBtn" prefHeight="35.0"
                        prefWidth="102.0"
                        style="-fx-background-color: transparent; -fx-border-color: #BDC3C7; -fx-border-radius: 2; -fx-text-fill: #34495E; -fx-padding: 8;"
                        text="Tareas totales">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </Button>

            </VBox>

            <VBox spacing="15"
                  style="-fx-background-color: white; -fx-background-radius: 4; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-border-color: #E0E0E0; -fx-border-radius: 4;">

                <Label style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #2C3E50;"
                       text="Listado de Tareas"/>

                <TableView fx:id="tareaTabla" onMouseClicked="#cargarTareaFormulario" prefHeight="450" prefWidth="680"
                           style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 2;">

                    <columns>
                        <TableColumn fx:id="idTareaColumna" prefWidth="50" text="ID"/>
                        <TableColumn fx:id="nombreTareaColumna" prefWidth="250" text="TAREA"/>
                        <TableColumn fx:id="responsableColumna" prefWidth="200" text="RESPONSABLE"/>
                        <TableColumn fx:id="estadoColumna" prefWidth="150" text="ESTADO"/>
                    </columns>

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>

                </TableView>

            </VBox>

        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" prefHeight="96.0" prefWidth="1100.0" spacing="15"
              style="-fx-padding: 15; -fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-width: 1 0 0 0;">

            <Button onAction="#agregarTarea"
                    style="-fx-background-color: #2C3E50; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 2; -fx-padding: 8 25; -fx-font-weight: 400;"
                    text="Agregar">
                <cursor>
                    <Cursor fx:constant="HAND"/>
                </cursor>
            </Button>

            <Button onAction="#editarBoton"
                    style="-fx-background-color: #34495E; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 2; -fx-padding: 8 25; -fx-font-weight: 400;"
                    text="Modificar">
                <cursor>
                    <Cursor fx:constant="HAND"/>
                </cursor>
            </Button>

            <Button onAction="#eliminarBoton"
                    style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 2; -fx-padding: 8 25; -fx-font-weight: 400;"
                    text="Eliminar">
                <cursor>
                    <Cursor fx:constant="HAND"/>
                </cursor>
            </Button>

            <Button onAction="#limpiarFormulario"
                    style="-fx-background-color: #95A5A6; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 2; -fx-padding: 8 25; -fx-font-weight: 400;"
                    text="Limpiar">
                <cursor>
                    <Cursor fx:constant="HAND"/>
                </cursor>
            </Button>

        </HBox>
    </bottom>

</BorderPane>
